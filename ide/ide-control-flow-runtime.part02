iles[out]=enc(c.data,out);c.changed=1;let z=stats(c.data);sec('Bacterial genome assembled',{p:['Browser method: exact suffix-overlap assembly for small datasets. This is not SPAdes.',`Contigs\n${z.count}`,`Assembly bases\n${z.total}`,`N50\n${z.n50}`],file:out})}
function qc(c,n,folder,l){let d=open(c,n,l),z=stats(d),rows=[{contigs:z.count,total_bases:z.total,n50:z.n50,longest:z.longest,shortest:z.shortest,gc_percent:z.gc.toFixed(2)}],out=`${folder.replace(/[\\/]$/,'')}/assembly-summary.csv`;c.data={kind:'table',columns:Object.keys(rows[0]),rows,delimiter:',',sourceName:out};c.files[out]=enc(c.data,out);c.changed=1;sec('Assembly quality',{p:['Browser method: direct contig statistics. Translation keeps QUAST for full reports.'],table:{c:c.data.columns,r:rows},file:out})}
function annotate(c,n,folder,l){let d=open(c,n,l),rows=[];for(let r of d.records)for(let strand of [['+',r.sequence],['-',rc(r.sequence)]])for(let f=0;f<3;f++){let start=-1;for(let i=f;i<=strand[1].length-3;i+=3){let cod=strand[1].slice(i,i+3);if(start<0&&cod==='ATG')start=i;if(start>=0&&/TAA|TAG|TGA/.test(cod)){if(i+3-start>=90)rows.push({gene:`orf-${rows.length+1}`,contig:r.name,strand:strand[0],start:start+1,end:i+3,length:i+3-start});start=-1}}}let out=`${folder.replace(/[\\/]$/,'')}/browser-orfs.csv`;c.data={kind:'table',columns:['gene','contig','strand','start','end','length'],rows,delimiter:',',sourceName:out};c.files[out]=enc(c.data,out);c.changed=1;sec('Bacterial genome annotated',{p:['Browser method: six-frame start-to-stop ORF scan. This is not Prokka.',`Open reading frames\n${rows.length}`],table:{c:c.data.columns,r:rows},file:out})}
function screen(c,n,db,kind,l){let q=open(c,n,l),ref=find(c.files,db)||find(c.files,`${db}.fasta`)||find(c.files,`${db}.fa`);if(!ref){c.flags[kind]=0;sec(`${kind[0].toUpperCase()+kind.slice(1)} marker screening`,{kind:'warning',p:[`Add a local FASTA named ${db}.fasta to Files for browser screening.`]});return}let rr=open(c,ref,l),rows=[];for(let x of rr.records)for(let y of q.records)if(y.sequence.includes(x.sequence)||rc(y.sequence).includes(x.sequence))rows.push({marker:x.name,sequence:y.name,match:'exact contained sequence'});c.flags[kind]=rows.length;c.data={kind:'table',columns:['marker','sequence','match'],rows,delimiter:','};let out=`${kind}-markers.csv`;c.files[out]=enc(c.data,out);c.changed=1;sec(`${kind[0].toUpperCase()+kind.slice(1)} markers`,{p:['Browser method: exact contained-sequence matches against a local FASTA. This is not ABRicate.',`Matches\n${rows.length}`],table:{c:c.data.columns,r:rows},file:out})}
function classify(c,n,db,l){let q=open(c,n,l),ref=find(c.files,db)||find(c.files,`${db}.fasta`)||find(c.files,`${db}.fa`);if(!ref){sec('Organism identification',{kind:'warning',p:[`Add a local FASTA named ${db}.fasta for a browser comparison.`]});return}let rr=open(c,ref,l),km=new Set();for(let r of q.records.slice(0,4000))for(let i=0;i<=r.sequence.length-15;i+=5)km.add(r.sequence.slice(i,i+15));let rows=rr.records.map(r=>{let t=0,h=0;for(let i=0;i<=r.sequence.length-15;i+=5){t++;if(km.has(r.sequence.slice(i,i+15)))h++}return{reference:r.name,shared_kmers:h,score_percent:(t?h/t*100:0).toFixed(2)}}).sort((a,b)=>b.score_percent-a.score_percent);c.data={kind:'table',columns:['reference','shared_kmers','score_percent'],rows,delimiter:','};c.files['browser-classification.csv']=enc(c.data,'browser-classification.csv');c.changed=1;sec('Organism identification',{p:['Browser method: small local 15-mer comparison. This is not Kraken 2.',rows[0]?`Best local reference\n${rows[0].reference} (${rows[0].score_percent}%)`:'No references compared.'],table:{c:c.data.columns,r:rows},file:'browser-classification.csv'})}
function plasmids(c,n,folder,l){let d=open(c,n,l),r=d.records.filter(x=>x.sequence.length>=100&&overlap(x.sequence.slice(-60),x.sequence.slice(0,60))>=18),out=`${folder.replace(/[\\/]$/,'')}/plasmid-candidates.fasta`;c.data={kind:'seq',format:'fasta',records:r,sourceName:out};c.files[out]=enc(c.data,out);c.changed=1;c.flags.plasmids=r.length;sec('Plasmid candidates',{p:['Browser method: circular-end-overlap candidate scan. This is not MOB-recon.',`Candidates\n${r.length}`],file:out})}
async function statement(n,c,p){let t=repl(n.t,c),m;if(/^(Use|Load|Enable|Install)(?: the)? \.(microbiology|genomics)$/i.test(t))return;if(m=t.match(/^Open all (FASTQ|FASTA|CSV|TSV) files(?: in (.+?))? as ([\w-]+)$/i)){let typ=m[1].toLowerCase(),dir=(m[2]||'').toLowerCase(),names=Object.keys(c.files).filter(x=>(!dir||x.toLowerCase().startsWith(dir.replace(/[\\/]$/,'')+'/'))&&(typ==='fastq'?is(x,FQ):typ==='fasta'?is(x,FA):typ==='csv'?x.endsWith('.csv'):x.endsWith('.tsv')));c.cols.set(m[3].toLowerCase(),names.map(name=>({name})));sec('Sample collection',{p:[`${m[3]}\n${names.length} files`,...names]});return}if(/^Open the sample$/i.test(t)){if(!c.sample)throw new X('Open the sample must be inside a sample loop.',n.l);c.data=open(c,c.sample.name,n.l);sec('Opened the sample',{p:[c.sample.name]});return}if(m=t.match(/^Open the files (.+?) and (.+?) as a pair$/i)){let a=open(c,m[1],n.l),b=open(c,m[2],n.l);if(a.format!=='fastq'||b.format!=='fastq'||a.records.length!==b.records.length)throw new X('Both paired files must be matching FASTQ files.',n.l);c.data={kind:'pair',a,b};sec('Opened the pair',{p:[m[1],m[2],`Read pairs\n${a.records.length}`]});return}if(m=t.match(/^Open the file (.+)$/i)){c.data=open(c,m[1],n.l);sec('Opened the file',{p:[c.data.sourceName],big:count(c.data,c.data.kind==='table'?'rows':'