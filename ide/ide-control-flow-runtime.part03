sequences')});return}if(m=t.match(/^Call the result (.+)$/i)){if(!c.data)throw new X('There is no result to name.',n.l);c.named.set(m[1].toLowerCase(),cl(c.data));sec('Named result',{p:[m[1]]});return}if(m=t.match(/^Use (?:the result )?(.+)$/i),m&&c.named.has(m[1].toLowerCase())){c.data=cl(c.named.get(m[1].toLowerCase()));sec('Using named result',{p:[m[1]]});return}let rn=(t.match(/^Use the recipe (.+)$/i)||[])[1]?.toLowerCase()||t.toLowerCase();if(p.recipes.has(rn)){await nodes(p.recipes.get(rn).b,c,p);return}if(m=t.match(/^Make sure (.+)$/i)){let v=cond(m[1],c,n.l);decision(m[1],v,v?'continue':'stop',n.l);if(!v)throw new X(`The program stopped because this check was not true:\n${m[1]}.`,n.l);return}if(m=t.match(/^Show a warning(?: saying (.+))?$/i)){sec('Warning',{kind:'warning',p:[m[1]||'This sample needs attention.']});return}if(/^Stop the program$/i.test(t))throw new Stop;if(/^(Continue with the next sample|Skip this sample)$/i.test(t))throw new Next;if(/^Mark the sample for review$/i.test(t)){let x=c.sample?.name||c.data?.sourceName||'Current result';c.review.add(x);sec('Marked for review',{kind:'warning',p:[x]});return}if(m=t.match(/^Say (.+)$/i)){sec('Message',{p:[m[1]]});return}
if(/^(Prepare|Clean) (the )?bacterial( illumina)? reads$/i.test(t)||/^Prepare reads for bacterial analysis$/i.test(t))return prep(c,n.l);if(m=t.match(/^(Assemble|Build) (the |a )?bacterial genome from (.+?) and (.+?) into (.+)$/i))return assemble(c,[m[3],m[4]],m[5],n.l);if(m=t.match(/^(Assemble|Build) (the |a )?bacterial genome from (.+?) into (.+)$/i))return assemble(c,[m[3]],m[4],n.l);if(m=t.match(/^(Check|Evaluate|Assess) (the )?(bacterial )?assembly (.+?) into (.+)$/i))return qc(c,m[4],m[5],n.l);if(m=t.match(/^(Annotate (the |a )?bacterial genome|Find genes in (the )?bacterial genome) (.+?) into (.+)$/i))return annotate(c,m[4],m[5],n.l);if(m=t.match(/^(Find resistance genes in (.+?) using (.+)|Screen (.+?) for resistance genes using (.+))$/i))return screen(c,m[2]||m[4],m[3]||m[5],'resistance',n.l);if(m=t.match(/^(Find virulence genes in (.+)|Screen (.+) for virulence genes)$/i))return screen(c,m[2]||m[3],'virulence-markers','virulence',n.l);if(m=t.match(/^(Identify (the )?organism in (.+?) using (.+)|Classify (.+?) using (.+))$/i))return classify(c,m[3]||m[5],m[4]||m[6],n.l);if(m=t.match(/^(Find plasmids in (.+?) into (.+)|Reconstruct plasmids from (.+?) into (.+))$/i))return plasmids(c,m[2]||m[4],m[3]||m[5],n.l);
if(m=t.match(/^Count the (rows|reads|sequences|bases)$/i)){sec(m[1][0].toUpperCase()+m[1].slice(1),{big:count(c.data,m[1])});return}if(/^(?:Check the quality(?: again)?|Show the quality report)$/i.test(t)){let z=stats(c.data);sec('Quality checked',{p:[`Reads\n${z.count}`,`Average quality\n${z.q.toFixed(1)}`]});return}if(/^Remove reads with low quality$/i.test(t))t='Remove reads with average quality below 20';if(m=t.match(/^(Keep reads with average quality at least|Remove reads with average quality below) ([\d.]+)$/i)){let q=+m[2];if(c.data.kind==='pair'){let k=[];for(let i=0;i<c.data.a.records.length;i++){let x=c.data.a.records[i],y=c.data.b.records[i];if(aq(x)>=q&&aq(y)>=q)k.push([x,y])}c.data.a.records=k.map(x=>x[0]);c.data.b.records=k.map(x=>x[1])}else c.data.records=c.data.records.filter(x=>aq(x)>=q);return}if(m=t.match(/^(Keep (sequences|reads) at least|Remove (sequences|reads) shorter than) (\d+) bases( long)?$/i)){let q=+m[4];if(c.data.kind==='pair'){let k=[];for(let i=0;i<c.data.a.records.length;i++){let x=c.data.a.records[i],y=c.data.b.records[i];if(x.sequence.length>=q&&y.sequence.length>=q)k.push([x,y])}c.data.a.records=k.map(x=>x[0]);c.data.b.records=k.map(x=>x[1])}else c.data.records=c.data.records.filter(x=>x.sequence.length>=q);return}if(/^Show the (result|file|sequences|reads)$/i.test(t)){let d=c.data;if(d.kind==='table')sec('The result',{table:{c:d.columns,r:d.rows}});else sec('The sequences',{table:{c:['name','length','sequence'],r:rec(d).map(x=>({name:x.name,length:x.sequence.length,sequence:x.sequence}))}});return}if(m=t.match(/^Save the pair as (.+?) and (.+)$/i)){if(c.data.kind!=='pair')throw new X('There is no open FASTQ pair.',n.l);c.files[m[1]]=enc(c.data.a,m[1]);c.files[m[2]]=enc(c.data.b,m[2]);c.changed=1;sec('Saved the pair',{p:[m[1],m[2]]});return}if(m=t.match(/^Save the (result|sequences|reads) as (.+)$/i)){if(!c.data)throw new X('There is no result to save.',n.l);c.files[m[2]]=enc(c.data,m[2]);c.changed=1;sec('Saved the result',{file:m[2]});return}if(/^Save the (result|sequences|reads) using the sample name$/i.test(t)){let out=`${st(c.sample?.name)}-result${c.data.kind==='table'?'.csv':'.fasta'}`;c.files[out]=enc(c.data,out);c.changed=1;sec('Saved the result',{file:out});return}let handlers=window.FigureLoomBioStatementHandlers||[];for(let handler of handlers){let handled=await handler({text:t,context:c,line:n.l,helpers:{section:sec,stats,records:rec,encode:enc,open:(name)=>open(c,name,n.l),findFile:(name)=>find(c.files,name),clone:cl,Error:X}});if(handled)return}throw new X(`I do not understand this instruction yet.\n\nI read: ${n.t}.`,n.l)}
async function nodes(a,c,p){for(let n of a){if(n.type==='recipe')continue;if(n.type==='s'){await statement(n,c,p);continue}if(n.type==='if'){let done=0;for(let b of n.bs){let v=cond(b.q,c,b.l);decision(b.q,v,v?'If':'next choice',b.l);if(v){await nodes(b.b,c,p);done=1;break}}if(!done&&n.o.length){sec('Decision',{p:['No earlier condition matched.','The program followed the Otherwise path.']});await nodes(n.o,c,p)}}if(n.type==='for'){let a=c.cols.get(n.col);if(!a)throw new X(`I could not find a collection called ${n.col}.`,n.l);for(let i=0;i<a.length;i++){c.sample=a[i];sec(`Sample ${i+1} of ${a.length}`,{p:[c.sample.name]});try{await nodes(n.b,c,p)}catch(e){if(e instanceof Next)continue;throw e}}c.sample=null}}}
