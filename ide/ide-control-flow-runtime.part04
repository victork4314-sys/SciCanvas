 .+:|Otherwise.*:|For every .+:|Make a recipe called .+:)/im.test(src)||/(Call the result|Make sure|Show a warning|Open all (FASTQ|FASTA|CSV|TSV) files|\.microbiology|bacterial genome|bacterial reads|resistance genes|virulence genes|plasmids|identify the organism)/i.test(src)||((window.FigureLoomBioCurrentFile?.normalizeSource?.(src)||src)!==src)||(window.FigureLoomBioStatementRecognizers||[]).some(recognizer=>{try{return recognizer(src)}catch{return false}})}
async function run(){R.replaceChildren();status('Running','running');B.disabled=1;let c={files:files(),data:null,named:new Map,cols:new Map,review:new Set,flags:{},sample:null,changed:0};try{let source=window.FigureLoomBioCurrentFile?.normalizeSource?.(E.value)||E.value;let p=parse(source);await nodes(p.b,c,p);if(c.review.size)sec('Review list',{table:{c:['sample'],r:[...c.review].map(sample=>({sample}))}});saveFiles(c.files);localStorage.setItem(AK,document.getElementById('programName')?.value||'example.flbio');status('Finished');if(c.changed)setTimeout(()=>location.reload(),100)}catch(e){if(e instanceof Stop){saveFiles(c.files);sec('Program stopped',{p:['The program followed a Stop instruction.']});status('Stopped')}else if(e instanceof X)err(e);else{console.error(e);err(new X('Something unexpected stopped the program.'))}}finally{B.disabled=0;persist()}}
window.addEventListener('click',e=>{let t=e.target instanceof Element?e.target.closest('#runButton'):null;if(!t||!use(E.value))return;e.preventDefault();e.stopImmediatePropagation();run()},true);document.addEventListener('keydown',e=>{if(!(e.ctrlKey||e.metaKey)||e.key!=='Enter'||!use(E.value))return;e.preventDefault();e.stopImmediatePropagation();run()},true);window.FigureLoomBioStatementHandlers=window.FigureLoomBioStatementHandlers||[];window.FigureLoomBioStatementRecognizers=window.FigureLoomBioStatementRecognizers||[];window.FigureLoomBioFlow={parseProgram:parse,usesAdvancedRuntime:use,conditionValue:cond,registerStatementHandler(handler,recognizer){if(typeof handler==='function'&&!window.FigureLoomBioStatementHandlers.includes(handler))window.FigureLoomBioStatementHandlers.push(handler);if(typeof recognizer==='function'&&!window.FigureLoomBioStatementRecognizers.includes(recognizer))window.FigureLoomBioStatementRecognizers.push(recognizer)}};})();