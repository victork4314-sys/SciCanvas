{
  "version": 1,
  "description": "Accepted natural forms that map to the built-in FigureLoom Bio language. Patterns omit final punctuation and are matched case-insensitively.",
  "rules": [
    {"id":"print_message","action":"say","pattern":"print (.+)","canonical":"Say $1.","examples":["Print The analysis is starting."]},
    {"id":"warn_message","action":"show_warning","pattern":"(?:warn[: ]+|show a warning:[ ]*)(.+)","canonical":"Show a warning saying $1.","examples":["Warn This sample needs review.","Show a warning: This sample needs review."]},

    {"id":"open_short","action":"open_file","pattern":"open (?!the files? )(.+\\.(?:csv|tsv|fa|fasta|fna|ffn|faa|frn|fq|fastq))","canonical":"Open the file $1.","examples":["Open samples.csv.","Open reads.fastq."]},
    {"id":"show_current_file","action":"show_file","pattern":"(?:show|display) the current file","canonical":"Show the file.","examples":["Show the current file.","Display the current file."]},
    {"id":"show_current_result","action":"show_result","pattern":"display the result","canonical":"Show the result.","examples":["Display the result."]},
    {"id":"save_current_file","action":"save_file","pattern":"save the current file as (.+)","canonical":"Save the file as $1.","examples":["Save the current file as output.fasta."]},
    {"id":"check_current_file","action":"check_file","pattern":"check the current file","canonical":"Check the file.","examples":["Check the current file."]},
    {"id":"count_current_file","action":"count_file","pattern":"count the current file","canonical":"Count the file.","examples":["Count the current file."]},
    {"id":"copy_current_file","action":"copy_file","pattern":"copy the current file as (.+)","canonical":"Copy the file as $1.","examples":["Copy the current file as backup.fasta."]},
    {"id":"rename_current_file","action":"rename_file","pattern":"rename the current file to (.+)","canonical":"Rename the file to $1.","examples":["Rename the current file to renamed.fasta."]},

    {"id":"keep_rows_where","action":"keep_rows","pattern":"keep (?:only )?rows where (.+?) is (.+)","canonical":"Keep only rows marked $2 under $1.","examples":["Keep rows where condition is treated."]},
    {"id":"remove_rows_where","action":"remove_rows","pattern":"remove rows where (.+?) is (.+)","canonical":"Remove rows marked $2 under $1.","examples":["Remove rows where status is failed."]},
    {"id":"select_columns","action":"keep_columns","pattern":"(?:select|keep) the columns (.+)","canonical":"Keep only the columns $1.","examples":["Select the columns sample and condition.","Keep the columns sample and condition."]},
    {"id":"sort_rows","action":"order_rows","pattern":"sort the rows by (.+)","canonical":"Put the rows in order by $1.","examples":["Sort the rows by sample."]},
    {"id":"sort_largest","action":"largest_first","pattern":"sort (.+) largest first","canonical":"Put the largest $1 first.","examples":["Sort score largest first."]},
    {"id":"sort_smallest","action":"smallest_first","pattern":"sort (.+) smallest first","canonical":"Put the smallest $1 first.","examples":["Sort score smallest first."]},
    {"id":"drop_duplicate_rows","action":"remove_duplicates","pattern":"(?:drop|remove) duplicate rows (?:using|under) (.+)","canonical":"Remove duplicate rows using $1.","examples":["Drop duplicate rows using sample."]},
    {"id":"fill_empty_values","action":"replace_empty","pattern":"fill empty values under (.+?) with (.+)","canonical":"Replace empty values under $1 with $2.","examples":["Fill empty values under status with unknown."]},

    {"id":"keep_length_without_long","action":"keep_min_length","pattern":"keep (?:sequences|reads) at least ([1-9][0-9]*) bases","canonical":"Keep reads at least $1 bases long.","examples":["Keep reads at least 100 bases.","Keep sequences at least 500 bases."]},
    {"id":"keep_length_minimum","action":"keep_min_length","pattern":"keep (?:sequences|reads) with at least ([1-9][0-9]*) bases","canonical":"Keep sequences at least $1 bases long.","examples":["Keep reads with at least 100 bases."]},
    {"id":"remove_under_length","action":"remove_shorter","pattern":"remove (?:sequences|reads) (?:under|below) ([1-9][0-9]*) bases","canonical":"Remove reads shorter than $1 bases.","examples":["Remove reads under 100 bases.","Remove sequences below 500 bases."]},
    {"id":"keep_longer_sequences","action":"keep_strict_length","pattern":"keep (?:sequences|reads) longer than ([1-9][0-9]*) bases","canonical":"Keep only sequences longer than $1 bases.","examples":["Keep reads longer than 100 bases."]},
    {"id":"find_orfs","action":"find_open_reading_frames","pattern":"find ORFs","canonical":"Find open reading frames.","examples":["Find ORFs."]},
    {"id":"find_palindromic_sequences","action":"find_palindromes","pattern":"find palindromic sequences","canonical":"Find palindromes.","examples":["Find palindromic sequences."]},
    {"id":"find_duplicate_sequences","action":"find_repeated_sequences","pattern":"find duplicate sequences","canonical":"Find repeated sequences.","examples":["Find duplicate sequences."]},
    {"id":"join_all_sequences","action":"join_sequences","pattern":"join all sequences","canonical":"Join the sequences.","examples":["Join all sequences."]},
    {"id":"align_sequences","action":"compare_current_sequences","pattern":"align (?:the )?sequences","canonical":"Compare the sequences.","examples":["Align the sequences.","Align sequences."]},
    {"id":"make_alignment","action":"compare_current_sequences","pattern":"(?:make|create) an alignment","canonical":"Compare the sequences.","examples":["Make an alignment.","Create an alignment."]},
    {"id":"display_alignment","action":"show_alignment","pattern":"display the alignment","canonical":"Show the alignment.","examples":["Display the alignment."]},

    {"id":"read_statistic","action":"read_statistic","pattern":"(?:calculate|find|show) the (average|mean|median|standard deviation|minimum|maximum) (?:read )?(quality|length)","canonical":"Calculate the $1 read $2.","examples":["Calculate the average quality.","Calculate the median quality.","Calculate the standard deviation of quality.","Find the mean read length.","Show the maximum quality."]},
    {"id":"standard_deviation_of_quality","action":"read_statistic","pattern":"calculate the standard deviation of (?:read )?(quality|length)","canonical":"Calculate the standard deviation of read $1.","examples":["Calculate the standard deviation of quality.","Calculate the standard deviation of read length."]},
    {"id":"check_read_quality","action":"check_quality","pattern":"check (?:the )?read quality","canonical":"Check the quality.","examples":["Check read quality.","Check the read quality."]},
    {"id":"show_read_quality_report","action":"show_quality_report","pattern":"show the read quality report","canonical":"Show the quality report.","examples":["Show the read quality report."]},
    {"id":"remove_low_quality_reads","action":"remove_low_quality_default","pattern":"remove low[- ]quality reads","canonical":"Remove reads with low quality.","examples":["Remove low-quality reads."]},
    {"id":"trim_read_start","action":"trim_start","pattern":"trim ([1-9][0-9]*) bases from the beginning(?: of each read)?","canonical":"Trim $1 bases from the start.","examples":["Trim 5 bases from the beginning of each read."]},
    {"id":"trim_read_end","action":"trim_end","pattern":"trim ([1-9][0-9]*) bases from the end of each read","canonical":"Trim $1 bases from the end.","examples":["Trim 5 bases from the end of each read."]},

    {"id":"clean_bacterial_reads","action":"builtin_microbiology_prepare_reads","pattern":"clean (?:the )?bacterial reads","canonical":"Prepare bacterial reads.","examples":["Clean bacterial reads.","Clean the bacterial reads."]},
    {"id":"build_bacterial_genome","action":"assemble_current_bacterial_genome","pattern":"build (?:the |a )?bacterial genome","canonical":"Assemble the bacterial genome.","examples":["Build the bacterial genome."]},
    {"id":"annotate_current_genome","action":"annotate_current_file","pattern":"annotate (?:the )?(?:current )?genome","canonical":"Annotate the file.","examples":["Annotate the genome.","Annotate the current genome."]},
    {"id":"detect_resistance_genes","action":"find_resistance_current_file","pattern":"detect resistance genes(?: in the file)?","canonical":"Find resistance genes in the file.","examples":["Detect resistance genes.","Detect resistance genes in the file."]},
    {"id":"detect_virulence_genes","action":"find_virulence_current_file","pattern":"detect virulence genes(?: in the file)?","canonical":"Find virulence genes in the file.","examples":["Detect virulence genes."]},
    {"id":"classify_current_organism","action":"identify_current_file","pattern":"classify the organism in the file using (.+)","canonical":"Identify the organism in the file using $1.","examples":["Classify the organism in the file using bacteria-reference."]},
    {"id":"reconstruct_current_plasmids","action":"find_plasmids_current_file","pattern":"reconstruct plasmids(?: from the file)?","canonical":"Find plasmids in the file.","examples":["Reconstruct plasmids.","Reconstruct plasmids from the file."]},

    {"id":"call_variants","action":"find_variants","pattern":"(?:call|detect) variants","canonical":"Find variants.","examples":["Call variants.","Detect variants."]},
    {"id":"display_variants","action":"show_variants","pattern":"display the variants","canonical":"Show the variants.","examples":["Display the variants."]},
    {"id":"detect_genes","action":"find_genes","pattern":"detect genes","canonical":"Find genes.","examples":["Detect genes."]},
    {"id":"display_genes","action":"show_genes","pattern":"display the genes","canonical":"Show the genes.","examples":["Display the genes."]},
    {"id":"detect_signal_peptides","action":"find_signal_peptides","pattern":"detect signal peptides","canonical":"Find signal peptides.","examples":["Detect signal peptides."]},
    {"id":"find_membrane_regions","action":"find_transmembrane_regions","pattern":"find (?:transmembrane|membrane) regions","canonical":"Find transmembrane regions.","examples":["Find membrane regions."]},
    {"id":"design_pcr_primers","action":"find_pcr_primers","pattern":"design PCR primers","canonical":"Find PCR primers.","examples":["Design PCR primers."]},
    {"id":"validate_primers","action":"check_primers","pattern":"validate the primers","canonical":"Check the primers.","examples":["Validate the primers."]},
    {"id":"display_primers","action":"show_primers","pattern":"display the primers","canonical":"Show the primers.","examples":["Display the primers."]},

    {"id":"create_phylogenetic_tree","action":"build_phylogenetic_tree","pattern":"(?:create|make|calculate) a phylogenetic tree","canonical":"Build a phylogenetic tree.","examples":["Create a phylogenetic tree.","Make a phylogenetic tree."]},
    {"id":"build_tree_short","action":"build_phylogenetic_tree","pattern":"build the tree","canonical":"Build a phylogenetic tree.","examples":["Build the tree."]},
    {"id":"display_tree","action":"show_tree","pattern":"display the tree","canonical":"Show the tree.","examples":["Display the tree."]},

    {"id":"average_column","action":"summary_statistic","pattern":"(?:calculate|find|show) the (average|mean|median|standard deviation|confidence interval) (?:of|under|for) (?!(?:read )?(?:quality|length)$)(.+)","canonical":"Calculate the $1 of $2.","examples":["Find the mean of score.","Calculate the median under score.","Show the confidence interval for score."]},
    {"id":"minimum_column","action":"calculate_minimum","pattern":"(?:calculate|find|show) the minimum (?:of|under|for) (.+)","canonical":"Calculate the minimum under $1.","examples":["Find the minimum of score."]},
    {"id":"maximum_column","action":"calculate_maximum","pattern":"(?:calculate|find|show) the maximum (?:of|under|for) (.+)","canonical":"Calculate the maximum under $1.","examples":["Find the maximum of score."]},
    {"id":"normalize_column","action":"normalize_counts","pattern":"normalize (?!the counts under )(.+)","canonical":"Normalize the counts under $1.","examples":["Normalize expression.","Normalize count."]},
    {"id":"normalize_counts_in","action":"normalize_counts","pattern":"normalize the counts (?:in|of) (.+)","canonical":"Normalize the counts under $1.","examples":["Normalize the counts in expression."]},
    {"id":"compare_groups_using","action":"compare_groups","pattern":"compare (.+?) and (.+?) using (.+)","canonical":"Compare $1 and $2 under $3.","examples":["Compare treated and control using group."]},
    {"id":"p_value_hyphen","action":"permutation_p_value","pattern":"calculate the p-value for (.+?) between (.+?) and (.+?) (?:under|using) (.+)","canonical":"Calculate the p value for $1 between $2 and $3 under $4.","examples":["Calculate the p-value for expression between treated and control using group."]},

    {"id":"make_histogram","action":"histogram","pattern":"(?:make|draw|create) a histogram (?:of|from|using) (.+)","canonical":"Create a histogram of $1.","examples":["Make a histogram of expression.","Draw a histogram using expression."]},
    {"id":"make_bar_chart_one","action":"bar_chart","pattern":"(?:make|draw|create) a bar chart (?:of|using) ([^,]+)","canonical":"Create a bar chart of $1.","examples":["Make a bar chart of expression."]},
    {"id":"make_bar_chart_two","action":"create_bar_chart","pattern":"(?:make|draw|create) a bar chart (?:from|using) (.+?) and (.+)","canonical":"Create a bar chart from $1 and $2.","examples":["Create a bar chart using sample and expression."]},
    {"id":"make_scatter_plot","action":"scatter_plot","pattern":"(?:make|draw|create) a scatter plot (?:of|from|using) (.+?) and (.+)","canonical":"Create a scatter plot of $1 and $2.","examples":["Create a scatter plot using expression and fold_change.","Draw a scatter plot from x and y."]},
    {"id":"grouped_box_plot","action":"grouped_box_plot","pattern":"(?:make|draw|create) a box plot (?:of|from|using) (.+?) (?:under|by|grouped by) (.+)","canonical":"Create a box plot of $1 under $2.","examples":["Create a box plot of expression under group.","Make a box plot of score grouped by condition."]},
    {"id":"make_box_plot","action":"box_plot","pattern":"(?:make|draw|create) a box plot (?:of|from|using) (.+)","canonical":"Create a box plot of $1.","examples":["Draw a box plot using expression."]},
    {"id":"heatmap_columns","action":"heat_map_columns","pattern":"(?:make|draw|create) a heat ?map (?:of|from|using) (.+)","canonical":"Create a heat map using $1.","examples":["Create a heat map using expression.","Draw a heatmap from gene_a and gene_b."]},
    {"id":"make_heatmap","action":"heat_map","pattern":"(?:make|draw) a heat ?map","canonical":"Create a heat map.","examples":["Make a heat map.","Draw a heatmap."]},
    {"id":"make_pca_plot","action":"pca_plot","pattern":"(?:make|draw|create) a (?:PCA|principal component analysis) plot","canonical":"Create a PCA plot.","examples":["Make a PCA plot.","Create a principal component analysis plot."]},
    {"id":"make_volcano_plot","action":"volcano_plot","pattern":"(?:make|draw|create) a volcano plot (?:of|from|using) (.+?) and (.+)","canonical":"Create a volcano plot using $1 and $2.","examples":["Draw a volcano plot from fold_change and p_value."]}
  ]
}
